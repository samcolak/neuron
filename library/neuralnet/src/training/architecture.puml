@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src/training class structure

package "training" {
  enum TrainerBridgeTarget
  class TrainerBatch {
    + label: String
    + samples: Vec<MultiModalInput>
    + new(label: &str, samples: Vec<MultiModalInput>): TrainerBatch
  }

  class TrainerBatchReport {
    + total_examples: usize
    + trained_examples: usize
    + skipped_examples: usize
    + per_label_counts: BTreeMap<String, usize>
  }

  class TrainerEvaluationSample {
    + expected_label: String
    + content: MultiModalInput
    + new(expected_label: &str, content: MultiModalInput): TrainerEvaluationSample
  }

  class TrainerEvaluationReport {
    + total_samples: usize
    + evaluated_samples: usize
    + correct_predictions: usize
    + unknown_predictions: usize
    + skipped_samples: usize
    + accuracy: f64
    + macro_precision: f64
    + macro_recall: f64
    + macro_f1: f64
    + micro_precision: f64
    + micro_recall: f64
    + micro_f1: f64
  }

  class LabelQualityMetrics {
    + precision: f64
    + recall: f64
    + f1: f64
    + support: usize
  }

  class TrainingLoopConfig {
    + epochs: usize
    + target: TrainerBridgeTarget
    + dendrite_type: DendriteType
    + early_stopping_patience: Option<usize>
    + early_stopping_min_delta: f64
    + checkpoint_dir: Option<PathBuf>
    + checkpoint_every_n_epochs: Option<usize>
    + start_from_checkpoint_id: Option<String>
    + save_best_checkpoint: bool
    + save_last_checkpoint: bool
  }

  class EpochTrainingSummary {
    + epoch: usize
    + trained_examples: usize
    + skipped_examples: usize
    + validation_accuracy: f64
    + validation_macro_f1: f64
    + validation_micro_f1: f64
  }

  class TrainingLoopReport {
    + epochs_ran: usize
    + best_epoch: Option<usize>
    + best_validation_accuracy: f64
    + history: Vec<EpochTrainingSummary>
    + final_validation: Option<TrainerEvaluationReport>
    + epoch_checkpoint_paths: BTreeMap<usize, Vec<PathBuf>>
    + best_checkpoint_paths: Vec<PathBuf>
    + last_checkpoint_paths: Vec<PathBuf>
    + resumed_from_checkpoint: Option<String>
  }

  enum LinearOptimizer {
    Sgd
    Adam
  }

  enum OptimizerState {
    Sgd
    Adam
  }

  class DenseTokenBaseline {
    + train_epoch(...): TrainerBatchReport
    + evaluate_dataset(...): TrainerEvaluationReport
  }

  enum LinearHeadError

  class LinearHead {
    - input_dim: usize
    - output_dim: usize
    - learning_rate: f32
    - optimizer: LinearOptimizer
    - weight_decay: f32
    - weight_optimizer_state: OptimizerState
    - bias_optimizer_state: OptimizerState
    + new(input_dim: usize, output_dim: usize, learning_rate: f32): Result<LinearHead, LinearHeadError>
    + dimensions(): (usize, usize)
    + optimizer(): LinearOptimizer
    + learning_rate(): f32
    + set_optimizer(optimizer: LinearOptimizer)
    + set_weight_decay(weight_decay: f32)
    + configure_adam(beta1: f32, beta2: f32, epsilon: f32)
    + logits(features: &[f32]): Result<Vec<f32>, LinearHeadError>
    + probabilities(features: &[f32]): Result<Vec<f32>, LinearHeadError>
    + predict_class(features: &[f32]): Result<usize, LinearHeadError>
    + train_step(features: &[f32], target_class: usize): Result<f32, LinearHeadError>
    + train_step_with_input_gradient(...): Result<(f32, Vec<f32>), LinearHeadError>
    + train_batch(...): Result<f32, LinearHeadError>
    + train_batch_with_input_gradients(...): Result<(f32, Vec<Vec<f32>>), LinearHeadError>
  }
}

class MultiModalBrain <<external>>
class SupervisedSample <<external>>
interface TrainableModel <<external>>
class NodeMetadata <<external>>
class DendriteType <<external>>
class MultiModalInput <<external>>

TrainerBatch *-- MultiModalInput
TrainerEvaluationSample *-- MultiModalInput
TrainerEvaluationReport *-- LabelQualityMetrics

TrainingLoopConfig ..> TrainerBridgeTarget
TrainingLoopConfig ..> DendriteType
TrainingLoopReport *-- EpochTrainingSummary
TrainingLoopReport ..> TrainerEvaluationReport

DenseTokenBaseline ..> TrainableModel
DenseTokenBaseline ..> SupervisedSample
DenseTokenBaseline ..> TrainerBatchReport
DenseTokenBaseline ..> TrainerEvaluationReport

MultiModalBrain ..> TrainerBatch
MultiModalBrain ..> TrainerEvaluationSample
MultiModalBrain ..> TrainerBatchReport
MultiModalBrain ..> TrainerEvaluationReport

LinearHead ..> LinearHeadError
LinearHead ..> LinearOptimizer
LinearHead ..> OptimizerState
@enduml