@startuml tensor_architecture
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src/tensor class structure

package "tensor" {
  enum TensorError
  class Tensor4D {
    + n: usize
    + c: usize
    + h: usize
    + w: usize
    + data: Vec<f32>
    + zeros(n: usize, c: usize, h: usize, w: usize): Tensor4D
    + shape(): (usize, usize, usize, usize)
    + get(n: usize, c: usize, y: usize, x: usize): Result<f32, TensorError>
    + set(n: usize, c: usize, y: usize, x: usize, value: f32): Result<(), TensorError>
  }

  enum TensorIoError
  enum TensorAdapterError
  enum ImageTensorUtilityError

  interface TensorBackend {
    + name(): &'static str
    + training_capabilities(): BackendTrainingCapabilities
    + conv2d_valid(...): Result<Tensor4D, TensorError>
    + max_pool2d(...): Result<Tensor4D, TensorError>
    + global_average_pool2d(input: &Tensor4D): Result<Tensor4D, TensorError>
    + relu_inplace(input: &mut Tensor4D)
    + conv_relu_max_pool2d_valid(...): Result<Tensor4D, TensorError>
    + conv_blocks_to_feature_vec(...): Result<Vec<f32>, TensorError>
    + conv_block_backward_gradients(...): Result<ConvBlockBackwardGradients, TensorError>
  }

  class ConvBlockBackwardGradients {
    + kernel_grad: Tensor4D
    + bias_grad: Vec<f32>
    + input_grad: Option<Tensor4D>
  }

  class BackendTrainingCapabilities {
    + native_forward_execution: bool
    + native_backward_execution: bool
    + host_materializes_gradients: bool
    + device_resident_parameter_state: bool
    + device_side_parameter_updates: bool
  }

  class ConvParameterState {
    + new(kernels: Tensor4D, bias: Vec<f32>): ConvParameterState
    + kernels(): &Tensor4D
    + bias(): &[f32]
    + accumulate_gradients(kernel_grad: &Tensor4D, bias_grad: &[f32]): Result<(), TensorError>
    + apply_sgd_update(learning_rate: f32, batch_size: f32): Result<(), TensorError>
    + sync_backend_mirror()
    + refresh_host_from_backend()
  }

  enum ParameterResidency
  enum ParameterBackendKind

  class CpuTensorBackend
  class CudaTensorBackend
  class MlxTensorBackend

  class TensorAdapters <<module>> {
    + image_bytes_to_tensor_nchw(...): Result<Tensor4D, TensorAdapterError>
    + multimodal_input_to_tensor(...): Result<Tensor4D, TensorAdapterError>
  }

  class TensorIo <<module>> {
    + save_tensor(path: &Path, tensor: &Tensor4D): Result<(), TensorIoError>
    + load_tensor(path: &Path): Result<Tensor4D, TensorIoError>
  }

  class ImageUtils <<module>> {
    + resize_grayscale_nearest(...): Result<Vec<u8>, ImageTensorUtilityError>
    + center_crop_grayscale(...): Result<Vec<u8>, ImageTensorUtilityError>
  }

  class BackendSelector <<module>> {
    + active_backend(): &dyn TensorBackend
    + active_backend_name(): &'static str
    + active_backend_label(): &'static str
    + active_backend_training_capabilities(): BackendTrainingCapabilities
    + cuda_backend_available(): bool
    + mlx_backend_available(): bool
  }

  class Offloading <<module>>
}

class MultiModalInput <<external>>
class Image <<external>>

TensorBackend <|.. CpuTensorBackend
TensorBackend <|.. CudaTensorBackend
TensorBackend <|.. MlxTensorBackend
TensorBackend ..> BackendTrainingCapabilities
TensorBackend ..> ConvBlockBackwardGradients

Tensor4D ..> TensorError
Tensor4D ..> TensorBackend
ConvParameterState ..> Tensor4D
ConvParameterState ..> ParameterResidency
ConvParameterState ..> ParameterBackendKind

TensorIo ..> Tensor4D
TensorIo ..> TensorIoError

TensorAdapters ..> Tensor4D
TensorAdapters ..> TensorAdapterError
TensorAdapters ..> ImageUtils
TensorAdapters ..> MultiModalInput

ImageUtils ..> ImageTensorUtilityError
ImageUtils ..> Image

BackendSelector ..> TensorBackend
BackendSelector ..> BackendTrainingCapabilities
BackendSelector ..> Offloading
BackendSelector ..> CpuTensorBackend
BackendSelector ..> CudaTensorBackend
BackendSelector ..> MlxTensorBackend

Offloading *-- CpuTensorBackend
Offloading *-- CudaTensorBackend
Offloading *-- MlxTensorBackend
@enduml