@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src/tensor class structure

package "tensor" {
  enum TensorError
  class Tensor4D {
    + n: usize
    + c: usize
    + h: usize
    + w: usize
    + data: Vec<f32>
    + zeros(n: usize, c: usize, h: usize, w: usize): Tensor4D
    + shape(): (usize, usize, usize, usize)
    + get(n: usize, c: usize, y: usize, x: usize): Result<f32, TensorError>
    + set(n: usize, c: usize, y: usize, x: usize, value: f32): Result<(), TensorError>
  }

  enum TensorIoError
  enum TensorAdapterError
  enum ImageTensorUtilityError

  interface TensorBackend {
    + conv2d(...): Result<Tensor4D, TensorError>
    + relu(input: &Tensor4D): Result<Tensor4D, TensorError>
    + max_pool2d(...): Result<Tensor4D, TensorError>
  }

  class CpuTensorBackend
  class CudaTensorBackend
  class MlxTensorBackend

  class TensorAdapters <<module>> {
    + image_bytes_to_tensor_nchw(...): Result<Tensor4D, TensorAdapterError>
    + multimodal_input_to_tensor(...): Result<Tensor4D, TensorAdapterError>
  }

  class TensorIo <<module>> {
    + save_tensor(path: &Path, tensor: &Tensor4D): Result<(), TensorIoError>
    + load_tensor(path: &Path): Result<Tensor4D, TensorIoError>
  }

  class ImageUtils <<module>> {
    + resize_grayscale_nearest(...): Result<Vec<u8>, ImageTensorUtilityError>
    + center_crop_grayscale(...): Result<Vec<u8>, ImageTensorUtilityError>
  }

  class BackendSelector <<module>> {
    + active_backend(): &dyn TensorBackend
  }

  class Offloading <<module>>
}

class MultiModalInput <<external>>
class Image <<external>>

TensorBackend <|.. CpuTensorBackend
TensorBackend <|.. CudaTensorBackend
TensorBackend <|.. MlxTensorBackend

Tensor4D ..> TensorError
Tensor4D ..> TensorBackend

TensorIo ..> Tensor4D
TensorIo ..> TensorIoError

TensorAdapters ..> Tensor4D
TensorAdapters ..> TensorAdapterError
TensorAdapters ..> ImageUtils
TensorAdapters ..> MultiModalInput

ImageUtils ..> ImageTensorUtilityError
ImageUtils ..> Image

BackendSelector ..> TensorBackend
BackendSelector ..> Offloading

Offloading *-- CpuTensorBackend
Offloading *-- CudaTensorBackend
Offloading *-- MlxTensorBackend
@enduml