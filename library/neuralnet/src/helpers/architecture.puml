@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src/helpers class structure

package "helpers" {
  class Axon {
    + from: String
    + to: String
    + weight: i64
    + new(from: String, to: String, weight: i64): Axon
  }

  enum SupportedImageFormat

  class ImageByteBuffer {
    + width: u32
    + height: u32
    + channels: u8
    + format: SupportedImageFormat
    + bytes: Vec<u8>
    + as_slice(): &[u8]
  }

  enum ImageIoError

  enum MultiModalInput {
    Text
    ImageBytes
    FeatureTokens
  }

  class MultiModalController {
    + tokenize(content: &MultiModalInput): Vec<String>
    + normalize_token(token: &str): String
    + evaluate_match(left: &str, right: &str): (f64, Vec<String>)
    + cluster_key_for_token(token_key: &str): Option<String>
  }

  class LabeledPattern {
    + label: String
    + content: MultiModalInput
  }

  class ClassificationResult {
    + label: String
    + score: f64
  }

  class PatternClassifier {
    - patterns: Vec<LabeledPattern>
    - min_confidence: f64
    + new(): PatternClassifier
    + set_min_confidence(min_confidence: f64)
    + train_example(label: &str, content: MultiModalInput)
    + classify(input: &MultiModalInput): Option<ClassificationResult>
    + classify_top_k(input: &MultiModalInput, k: usize): Vec<ClassificationResult>
  }

  class MultiModalSubNetwork <<type alias>>
}

interface NodeNetworkController <<external>>
interface TokenClusterKeyStrategy <<external>>
interface NodeNetwork <<external>>
class NeuralNetwork <<external>>
class MultimodalDendrite <<external>>

TokenClusterKeyStrategy <|.. MultiModalController
NodeNetworkController <|.. MultiModalController

PatternClassifier *-- LabeledPattern
PatternClassifier ..> ClassificationResult
PatternClassifier ..> MultiModalInput
PatternClassifier ..> MultiModalController

MultiModalSubNetwork ..> NeuralNetwork
MultiModalSubNetwork ..> MultimodalDendrite
MultiModalSubNetwork ..> MultiModalController

ImageByteBuffer ..> SupportedImageFormat
ImageIoError <.. ImageByteBuffer
@enduml