@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src class structure overview

package "src" {
  class MultiModalBrain {
    + classify_pattern(content: &MultiModalInput): Option<ClassificationResult>
    + run_supervised_pipeline(...): BrainSupervisedPipelineReport
    + enable_auto_snapshot_in_dir(instance_id: &str, dir: &Path, every_n_inserts: usize)
    + flush_auto_snapshot(): io::Result<bool>
  }

  class NeuralNetwork {
    + insert_content(...)
    + enumerate_path_content(...)
  }

  interface NetworkNode
  interface NodeNetworkController

  class CnnImageClassifier {
    + train_image(...)
    + predict_with_confidence(...)
  }

  class CnnFeatureExtractor {
    + extract_feature_tokens(image: &[u8]): Result<Vec<String>, CnnFeatureExtractorError>
  }

  class PatternClassifier {
    + train_example(label: &str, content: MultiModalInput)
    + classify(input: &MultiModalInput): Option<ClassificationResult>
  }

  class RagPipeline {
    + answer_text(question: &str): RagAnswer
    + answer_with_brain(brain: &MultiModalBrain, input: &MultiModalInput): RagAnswer
  }

  interface Retriever {
    + retrieve(query: &str, top_k: usize): Vec<RagChunk>
  }

  interface Generator {
    + generate(question: &str, context: &RagContext): String
  }

  class BrainRagBridge {
    + query_from_input(input: &MultiModalInput): String
    + classify_hint(brain: &MultiModalBrain, input: &MultiModalInput): Option<ClassificationResult>
  }

  class RagDocument {
    + id: String
    + text: String
    + metadata: HashMap<String, String>
  }

  class RagChunk {
    + document_id: String
    + chunk_id: String
    + text: String
    + score: f64
  }

  class RagContext {
    + query: String
    + chunks: Vec<RagChunk>
  }

  class RagAnswer {
    + answer: String
    + context: RagContext
    + model_label_hint: Option<String>
    + model_score_hint: Option<f64>
  }

  class MultiModalController {
    + tokenize(content: &MultiModalInput): Vec<String>
    + evaluate_match(left: &str, right: &str): (f64, Vec<String>)
  }

  enum MultiModalInput

  class Tensor4D {
    + shape(): (usize, usize, usize, usize)
    + get(...): Result<f32, TensorError>
    + set(...): Result<(), TensorError>
  }

  interface TensorBackend {
    + training_capabilities(): BackendTrainingCapabilities
    + conv_block_backward_gradients(...): Result<ConvBlockBackwardGradients, TensorError>
  }

  class ConvBlockBackwardGradients {
    + kernel_grad: Tensor4D
    + bias_grad: Vec<f32>
    + input_grad: Option<Tensor4D>
  }

  class BackendTrainingCapabilities {
    + native_forward_execution: bool
    + native_backward_execution: bool
    + host_materializes_gradients: bool
  }

  class ConvParameterState {
    + accumulate_gradients(...): Result<(), TensorError>
    + apply_sgd_update(...): Result<(), TensorError>
    + sync_backend_mirror()
  }

  class TrainingLoopConfig {
    + epochs: usize
    + target: TrainerBridgeTarget
  }

  class TrainingLoopReport {
    + epochs_ran: usize
    + best_validation_accuracy: f64
  }

  class TrainerEvaluationReport {
    + accuracy: f64
    + macro_f1: f64
    + micro_f1: f64
  }

  class TextDendrite {
    + uid: String
    + data: String
  }

  class ImageDendrite {
    + uid: String
    + data: String
    + feature_type: String
  }

  class MultimodalDendrite {
    + uid: String
    + data: String
    + modality: String
  }
}

NodeNetworkController <|.. MultiModalController
PatternClassifier ..> MultiModalInput
MultiModalBrain *-- PatternClassifier
MultiModalBrain ..> CnnFeatureExtractor
MultiModalBrain ..> MultiModalInput

RagPipeline ..> Retriever
RagPipeline ..> Generator
RagPipeline ..> RagContext
RagPipeline ..> RagAnswer
RagPipeline ..> BrainRagBridge
RagPipeline ..> MultiModalBrain
BrainRagBridge ..> MultiModalInput
RagContext *-- RagChunk
RagAnswer *-- RagContext

Tensor4D ..> TensorBackend
TensorBackend ..> BackendTrainingCapabilities
TensorBackend ..> ConvBlockBackwardGradients
ConvParameterState ..> Tensor4D

NeuralNetwork ..> NetworkNode
NeuralNetwork ..> NodeNetworkController
MultimodalDendrite ..|> NetworkNode
TextDendrite ..|> NetworkNode
ImageDendrite ..|> NetworkNode

CnnImageClassifier ..> Tensor4D
CnnImageClassifier ..> ConvParameterState
TrainingLoopReport ..> TrainerEvaluationReport
TrainingLoopConfig ..> MultiModalBrain
@enduml