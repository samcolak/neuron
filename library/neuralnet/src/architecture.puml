@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src class structure overview

package "src" {
  class MultiModalBrain {
    + classify_pattern(content: &MultiModalInput): Option<ClassificationResult>
    + run_supervised_pipeline(...): BrainSupervisedPipelineReport
  }

  class NeuralNetwork {
    + insert_content(...)
    + enumerate_path_content(...)
  }

  interface NetworkNode
  interface NodeNetworkController

  class CnnImageClassifier {
    + train_image(...)
    + predict_with_confidence(...)
  }

  class CnnFeatureExtractor {
    + extract_feature_tokens(image: &[u8]): Result<Vec<String>, CnnFeatureExtractorError>
  }

  class PatternClassifier {
    + train_example(label: &str, content: MultiModalInput)
    + classify(input: &MultiModalInput): Option<ClassificationResult>
  }

  class MultiModalController {
    + tokenize(content: &MultiModalInput): Vec<String>
    + evaluate_match(left: &str, right: &str): (f64, Vec<String>)
  }

  enum MultiModalInput

  class Tensor4D {
    + shape(): (usize, usize, usize, usize)
    + get(...): Result<f32, TensorError>
    + set(...): Result<(), TensorError>
  }

  interface TensorBackend

  class TrainingLoopConfig {
    + epochs: usize
    + target: TrainerBridgeTarget
  }

  class TrainingLoopReport {
    + epochs_ran: usize
    + best_validation_accuracy: f64
  }

  class TrainerEvaluationReport {
    + accuracy: f64
    + macro_f1: f64
    + micro_f1: f64
  }

  class TextDendrite {
    + uid: String
    + data: String
  }

  class ImageDendrite {
    + uid: String
    + data: String
    + feature_type: String
  }

  class MultimodalDendrite {
    + uid: String
    + data: String
    + modality: String
  }
}

NodeNetworkController <|.. MultiModalController
PatternClassifier ..> MultiModalInput
MultiModalBrain *-- PatternClassifier
MultiModalBrain ..> CnnFeatureExtractor
MultiModalBrain ..> MultiModalInput

Tensor4D ..> TensorBackend

NeuralNetwork ..> NetworkNode
NeuralNetwork ..> NodeNetworkController
MultimodalDendrite ..|> NetworkNode
TextDendrite ..|> NetworkNode
ImageDendrite ..|> NetworkNode

CnnImageClassifier ..> Tensor4D
TrainingLoopReport ..> TrainerEvaluationReport
TrainingLoopConfig ..> MultiModalBrain
@enduml