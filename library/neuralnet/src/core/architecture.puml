@startuml core_architecture
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam monochrome true
skinparam classAttributeIconSize 0

title neuralnet/src/core class structure

package "core" {
  class MultiModalBrain {
    - cognitive_net: MultiModalSubNetwork
    - memory_net: MultiModalSubNetwork
    - classifier: PatternClassifier
    - image_feature_extractor: Option<CnnFeatureExtractor>
    - auto_snapshot: AutoSnapshotPolicy
    - transaction_log: AutoTransactionLogPolicy
    - query_cache_enabled: bool
    - query_score_cache: QueryScoreCache
    + new_multimodal(): MultiModalBrain
    + classify_pattern(content: &MultiModalInput): Option<ClassificationResult>
    + classify_pattern_top_k(content: &MultiModalInput, k: usize): Vec<ClassificationResult>
    + run_supervised_pipeline(...): BrainSupervisedPipelineReport
    + snapshot_instance(instance_id: &str): io::Result<()>
    + snapshot_instance_in_dir(instance_id: &str, dir: &Path): io::Result<()>
    + load_snapshot_instance(instance_id: &str): io::Result<SnapshotLoadStatus>
    + load_snapshot_instance_in_dir(instance_id: &str, dir: &Path): io::Result<SnapshotLoadStatus>
    + enable_auto_snapshot_in_dir(instance_id: &str, dir: &Path, every_n_inserts: usize)
    + flush_auto_snapshot(): io::Result<bool>
    + snapshot_bundle_path_for_instance_in_dir(instance_id: &str, dir: &Path): PathBuf
  }

  class AutoSnapshotPolicy {
    + instance_id: Option<String>
    + dir: Option<PathBuf>
    + every_n_inserts: usize
    + pending_inserts: usize
    + last_enqueued_generation: u64
  }

  class AutoTransactionLogPolicy {
    + instance_id: Option<String>
    + dir: Option<PathBuf>
    + last_enqueued_sequence: u64
    + replay_in_progress: bool
  }

  class QueryScoreCache {
    + with_capacity(capacity: usize): QueryScoreCache
    + get(key: &str): Option<f64>
    + insert(key: String, value: f64)
    + clear()
  }

  class NetworkDump {
    + name: String
    + nodes: Vec<MultimodalDendrite>
  }

  class BrainDump {
    + cognitive: NetworkDump
    + memory: NetworkDump
  }

  class SnapshotLoadStatus {
    + cognitive_loaded: bool
    + memory_loaded: bool
    + classifier_loaded: bool
  }

  enum QuestionStoreDecision

  class ProbePrediction {
    + input: MultiModalInput
    + prediction: Option<ClassificationResult>
  }

  class BrainSupervisedPipelineReport {
    + training_loop_report: TrainingLoopReport
    + final_evaluation: TrainerEvaluationReport
    + probe_predictions: Vec<ProbePrediction>
  }

  class SupervisedSample {
    + label: String
    + content: MultiModalInput
    + new(label: &str, content: MultiModalInput): SupervisedSample
  }

  interface TrainableModel {
    + train_epoch(...): TrainerBatchReport
    + evaluate_dataset(samples: &[SupervisedSample]): TrainerEvaluationReport
    + save_checkpoint(checkpoint_id: &str, dir: &Path): io::Result<Vec<PathBuf>>
    + load_checkpoint(checkpoint_id: &str, dir: &Path): io::Result<()>
  }

  class NeuralNetwork<C,N> {
    - dendrites: HashMap<String, N>
    - token_index: HashMap<String, Vec<String>>
    - token_cluster_index: HashMap<String, Vec<String>>
    - controller: C
    + insert_content(content: &C::Content, metadata: &NodeMetadata, dendrite_type: DendriteType)
    + enumerate_path_content(content: &C::Content): (Option<N>, Vec<N>)
  }

  class NodeMetadata {
    + attributes: HashMap<String, String>
    + new(): NodeMetadata
    + with_lang(language: &str): NodeMetadata
    + set(key: &str, value: &str)
    + get(key: &str): Option<&str>
  }

  interface NetworkNode {
    + new_node(data: &str, metadata: &NodeMetadata, dendrite_type: DendriteType): Self
    + uid(): &str
    + data(): &str
    + connect(other: String, weight: i64)
  }

  interface TokenClusterKeyStrategy {
    + cluster_key_for_token(token_key: &str): Option<String>
  }

  interface NodeNetworkController {
    + tokenize(content: &Content): Vec<String>
    + normalize_token(token: &str): String
    + evaluate_match(left: &str, right: &str): (f64, Vec<String>)
  }

  interface NodeNetwork {
    + insert_content(content: &Content, metadata: &NodeMetadata, dendrite_type: DendriteType)
    + enumerate_path_content(content: &Content): (Option<Node>, Vec<Node>)
  }
}

class CnnFeatureExtractor <<external>>
class MultiModalSubNetwork <<external>>
class PatternClassifier <<external>>
class ClassificationResult <<external>>
class MultiModalInput <<external>>
class DendriteType <<external>>
class TrainingLoopConfig <<external>>
class TrainingLoopReport <<external>>
class TrainerEvaluationReport <<external>>
class TrainerBatchReport <<external>>
class MultimodalDendrite <<external>>

MultiModalBrain *-- PatternClassifier
MultiModalBrain *-- MultiModalSubNetwork
MultiModalBrain *-- AutoSnapshotPolicy
MultiModalBrain *-- AutoTransactionLogPolicy
MultiModalBrain *-- QueryScoreCache
MultiModalBrain ..> CnnFeatureExtractor
MultiModalBrain ..> MultiModalInput
MultiModalBrain ..> DendriteType

TrainableModel <|.. MultiModalBrain
TrainableModel ..> SupervisedSample

NeuralNetwork ..> NodeNetworkController
NeuralNetwork ..> NetworkNode
NodeNetworkController ..|> TokenClusterKeyStrategy

ProbePrediction ..> MultiModalInput
ProbePrediction ..> PatternClassifier
BrainSupervisedPipelineReport *-- ProbePrediction
BrainSupervisedPipelineReport ..> TrainingLoopReport
BrainSupervisedPipelineReport ..> TrainerEvaluationReport

MultiModalBrain ..> QuestionStoreDecision
MultiModalBrain ..> NetworkDump
MultiModalBrain ..> BrainDump
MultiModalBrain ..> SnapshotLoadStatus
MultiModalBrain ..> TrainingLoopConfig
MultiModalBrain ..> TrainingLoopReport

NodeNetwork ..> NodeNetworkController
NodeNetwork ..> NetworkNode
@enduml